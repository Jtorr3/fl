    {
      "label": "Qeynos Audio Suite Work Order",
      "file_type": "document",
      "source_file": "WORK_ORDER.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "One VST at a time, each fully finished (DSP + GUI + presets + built VST3 + validated) before the next begins, so the run can stop at any point with everything completed so far usable in FL Studio.",
