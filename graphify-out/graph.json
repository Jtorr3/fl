    {
      "label": "Tech stack decisions (nih-plug / rustup-gnu / egui / pluginval)",
      "file_type": "rationale",
      "source_file": "WORK_ORDER.md",
      "source_location": "Tech stack",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "nih-plug: one-command cargo builds, no Steinberg SDK setup, exports VST3 (FL's format), excellent for autonomous iteration. gnu toolchain: zero admin rights, self-contained linker (MSVC Build Tools fallback). nih_plug_egui: most reliable to build unattended, shared dark theme for one product family. pluginval: catches crashes/param bugs without FL open. Documents\\VST3 install target avoids UAC prompts. FL runs all instances of one plugin DLL in one process, which is what makes the master/client mastering architecture possible via shared state.",
      "id": "work_order_tech_stack",
      "community": 2,
      "norm_label": "tech stack decisions (nih-plug / rustup-gnu / egui / pluginval)"
    },
